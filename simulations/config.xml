<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHY config for UCLA scenario (no obstacle shadowing - no building polygon data).

  SimplePathlossModel: alpha=2.75 (urban V2V per Karedal et al. 2009, Boban et al. 2014).
  Previous value 2.0 was free-space; 2.75 represents LOS urban street canyon.

  NakagamiFading: m=1.5 (urban NLOS typical), constM=true (constant m; Veins also
  supports distance-based m via constM=false with M_CLOSE=1.5, M_FAR=0.75).
  Note: m=1.5 is a single-value simplification; measurement campaigns show m varies
  with distance (close: m~2-3, far: m~0.75-1.0). Disclose in Limitations.
-->
<root>
    <AnalogueModels>
        <AnalogueModel type="SimplePathlossModel" thresholding="true">
            <parameter name="alpha" type="double" value="2.75"/>
        </AnalogueModel>
        <AnalogueModel type="NakagamiFading">
            <parameter name="constM" type="bool" value="true"/>
            <parameter name="m" type="double" value="1.5"/>
        </AnalogueModel>
    </AnalogueModels>
    <Decider type="Decider80211p">
        <parameter name="centerFrequency" type="double" value="5.890e9"/>
    </Decider>
</root>

